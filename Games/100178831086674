local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = _G.Gname .. " | DencoHub",
    LoadingTitle = "Last Update: " .. _G.Lastup,
    LoadingSubtitle = "by DencoHub",
    ConfigurationSaving = { Enabled = false }
})

local Tab = Window:CreateTab("Main", 4483362458)

local config = {
    AutoPass = false,
    AutoGet = false,
    AutoSave = false,
    CurrentTime = 99,
}

-- Bombayı Nesne Olarak Bul (Karakter yamulmaması için Part bazlı)
local function getBombObject()
    local bomb = workspace:FindFirstChild("TimeBomb", true) or (workspace:FindFirstChild("NoahPandt") and workspace.NoahPandt:FindFirstChild("TimeBomb"))
    if bomb then
        if bomb:IsA("BasePart") then return bomb end
        if bomb:FindFirstChild("Handle") then return bomb.Handle end
    end
    return nil
end

-- Mesafe Hesaplama (En uzaktaki kişiyi bulmak için)
local function getFarthestPlayer()
    local farthestPlayer = nil
    local maxDistance = -1
    local lp = game.Players.LocalPlayer
    if not lp.Character or not lp.Character:FindFirstChild("HumanoidRootPart") then return nil end

    for _, player in pairs(game.Players:GetPlayers()) do
        if player ~= lp and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (lp.Character.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
            if dist > maxDistance then
                maxDistance = dist
                farthestPlayer = player
            end
        end
    end
    return farthestPlayer
end

-- Zaman Senkronizasyonu
local timerRemote = game:GetService("ReplicatedStorage"):WaitForChild("BombRemotes"):WaitForChild("TimerSync")
timerRemote.OnClientEvent:Connect(function(serverTime)
    config.CurrentTime = serverTime
end)

-- ANA DÖNGÜ
task.spawn(function()
    while task.wait() do
        local lp = game.Players.LocalPlayer
        local char = lp.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then continue end

        local hrp = char.HumanoidRootPart
        local hasBomb = lp:FindFirstChild("TimeBomb", true) or char:FindFirstChild("TimeBomb", true)

        -- 1. AUTO SAVE (1 Saniye Kala Dikey Alış - Bombanın 4 birim üstüne)
        if config.AutoSave and not hasBomb and config.CurrentTime <= 1.1 then
            local bombObj = getBombObject()
            if bombObj then
                hrp.CFrame = CFrame.new(bombObj.Position + Vector3.new(0, 4, 0))
            end
        end

        -- 2. AUTO GET (2 Saniye Kalana Kadar Çalışır - Dik Durur)
        if config.AutoGet and not hasBomb and config.CurrentTime > 2 then
            local bombObj = getBombObject()
            if bombObj then
                hrp.CFrame = CFrame.new(bombObj.Position)
            end
        end

        -- 3. AUTO PASS (1 Saniye Kala Ver ve En Uzağa Kaç)
        if config.AutoPass and hasBomb and config.CurrentTime <= 1.2 then
            local victim = getFarthestPlayer()
            if victim and victim.Character and victim.Character:FindFirstChild("HumanoidRootPart") then
                -- Önce kurbana ışınlanıp bombayı ver
                hrp.CFrame = CFrame.new(victim.Character.HumanoidRootPart.Position)
                
                -- Kısa bir bekleme (Bombanın geçmesi için)
                task.wait(0.15)
                
                -- ŞİMDİ: Hemen o anki en uzak kişiye ışınlanarak kaç
                local escapeTarget = getFarthestPlayer()
                if escapeTarget and escapeTarget.Character and escapeTarget.Character:FindFirstChild("HumanoidRootPart") then
                    hrp.CFrame = CFrame.new(escapeTarget.Character.HumanoidRootPart.Position)
                end
            end
        end
    end
end)

