    config.CurrentTime = serverTime
end)

-- En uzaktaki oyuncuyu bulma fonksiyonu
local function getFarthestPlayer()
    local farthestPlayer = nil
    local maxDistance = -1
    local lp = game.Players.LocalPlayer
    if not lp.Character or not lp.Character:FindFirstChild("HumanoidRootPart") then return nil end

    for _, player in pairs(game.Players:GetPlayers()) do
        if player ~= lp and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (lp.Character.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
            if dist > maxDistance then
                maxDistance = dist
                farthestPlayer = player
            end
        end
    end
    return farthestPlayer
end

-- Bombanın şu an kimde olduğunu bulma
local function getBombCarrier()
    local bombPath = workspace:FindFirstChild("NoahPandt") and workspace.NoahPandt:FindFirstChild("TimeBomb")
    if bombPath then
        for _, p in pairs(game.Players:GetPlayers()) do
            if p.Character and bombPath:IsDescendantOf(p.Character) then
                return p
            end
        end
    end
    return nil
end

-- Ana Döngü
task.spawn(function()
    while task.wait() do
        if config.Enabled then
            local lp = game.Players.LocalPlayer
            local char = lp.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then continue end

            local hasBomb = lp:FindFirstChild("TimeBomb", true) or (char and char:FindFirstChild("TimeBomb", true))
            
            if not hasBomb then
                -- 1. ADIM: Bombayı çalmak için sahibine git
                local carrier = getBombCarrier()
                if carrier and carrier.Character and carrier.Character:FindFirstChild("HumanoidRootPart") then
                    char.HumanoidRootPart.CFrame = carrier.Character.HumanoidRootPart.CFrame
                end
            else
                -- 2. ADIM: Bomba sendeyse süre 3'e kadar BEKLE (Güvenli bir yerde veya havada bekleyebilirsin)
                if config.CurrentTime > 3 then
                    -- 3 saniyeden fazlaysa bombayı patlatmamak için kimseye yaklaşma (Havada asılı kalabilirsin)
                    char.HumanoidRootPart.CFrame = char.HumanoidRootPart.CFrame * CFrame.new(0, 0.1, 0) 
                elseif config.CurrentTime <= 3 then
                    -- 3. ADIM: Süre 3 oldu! En uzaktaki kurbanın sol arkasına ışınlan
                    local victim = getFarthestPlayer()
                    if victim and victim.Character and victim.Character:FindFirstChild("HumanoidRootPart") then
                        -- Sol Arka (-2 Sol, 2 Arka)
                        char.HumanoidRootPart.CFrame = victim.Character.HumanoidRootPart.CFrame * CFrame.new(-2, 0, 2)
                        
                        -- Bombanın geçtiğinden emin olana kadar kısa bir süre bekle
                        task.wait(0.2)
                        
                        -- 4. ADIM: Bombayı verdikten sonra hemen en uzak noktaya kaç
                        local escapeTarget = getFarthestPlayer()
                        if escapeTarget and escapeTarget.Character then
                             char.HumanoidRootPart.CFrame = escapeTarget.Character.HumanoidRootPart.CFrame * CFrame.new(0, 50, 0) -- Havaya kaçış
                        end
                    end
                end
            end
        end
    end
end)

