local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = _G.Gname .. " | DencoHub",
    LoadingTitle = "Last update: " .. _G.Lastup,
    LoadingSubtitle = "by DencoHub",
    ConfigurationSaving = { Enabled = false }
})

local Tab = Window:CreateTab("Main", 4483362458)

local config = {
    AutoPass = false,
    AutoGet = false,
    AutoSave = false,
    CurrentTime = 99,
    TargetPlayer = nil -- Seçilen hedef oyuncu
}

-- Bombayı Nesne Olarak Bul (Karakter dik duruşu için)
local function getBombObject()
    local bomb = workspace:FindFirstChild("TimeBomb", true) or (workspace:FindFirstChild("NoahPandt") and workspace.NoahPandt:FindFirstChild("TimeBomb"))
    if bomb then
        if bomb:IsA("BasePart") then return bomb end
        if bomb:FindFirstChild("Handle") then return bomb.Handle end
    end
    return nil
end

-- En Uzaktaki Oyuncuyu Bul (Kaçış ve Yedek Hedef İçin)
local function getFarthestPlayer()
    local farthestPlayer = nil
    local maxDistance = -1
    local lp = game.Players.LocalPlayer
    for _, player in pairs(game.Players:GetPlayers()) do
        if player ~= lp and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (lp.Character.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
            if dist > maxDistance then
                maxDistance = dist
                farthestPlayer = player
            end
        end
    end
    return farthestPlayer
end

-- Oyuncu Listesini Al (Dropdown için)
local function getPlayerNames()
    local names = {"None (Farthest)"}
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= game.Players.LocalPlayer then
            table.insert(names, p.Name)
        end
    end
    return names
end

-- Zaman Senkronizasyonu
local timerRemote = game:GetService("ReplicatedStorage"):WaitForChild("BombRemotes"):WaitForChild("TimerSync")
timerRemote.OnClientEvent:Connect(function(serverTime)
    config.CurrentTime = serverTime
end)

-- ANA DÖNGÜ
task.spawn(function()
    while task.wait() do
        local lp = game.Players.LocalPlayer
        local char = lp.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then continue end

        local hrp = char.HumanoidRootPart
        local hasBomb = lp:FindFirstChild("TimeBomb", true) or char:FindFirstChild("TimeBomb", true)

        -- 1. AUTO SAVE (1s - Üstten Alma)
        if config.AutoSave and not hasBomb and config.CurrentTime <= 1.1 then
            local bombObj = getBombObject()
            if bombObj then
                hrp.CFrame = CFrame.new(bombObj.Position + Vector3.new(0, 4, 0))
            end
        end

        -- 2. AUTO GET (> 2s - Kovala)
        if config.AutoGet and not hasBomb and config.CurrentTime > 2 then
            local bombObj = getBombObject()
            if bombObj then
                hrp.CFrame = CFrame.new(bombObj.Position)
            end
        end

        -- 3. AUTO PASS (1s - Seçili Kişiye Ver ve Kaç)
        if config.AutoPass and hasBomb and config.CurrentTime <= 1.2 then
            local target = nil
            
            -- Eğer bir hedef seçilmişse onu bul
            if config.TargetPlayer and config.TargetPlayer ~= "None (Farthest)" then
                local p = game.Players:FindFirstChild(config.TargetPlayer)
                if p and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    target = p
                end
            end
            
            -- Hedef seçilmemişse veya oyundan çıkmışsa en uzağa git
            if not target then
                target = getFarthestPlayer()
            end

            if target and target.Character then
                hrp.CFrame = CFrame.new(target.Character.HumanoidRootPart.Position)
                task.wait(0.15)
                
                -- Kaçış: En uzak noktaya ışınlan
                local escape = getFarthestPlayer()
                if escape and escape.Character then
                    hrp.CFrame = CFrame.new(escape.Character.HumanoidRootPart.Position)
                end
            end
        end
    end
end)

--- ARAYÜZ ---

local PlayerDropdown = Tab:CreateDropdown({
    Name = "Select Target Player",
    Options = getPlayerNames(),
    CurrentOption = "None (Farthest)",
    Flag = "TargetDropdown",
    Callback = function(Option)
        config.TargetPlayer = Option
    end,
})

Tab:CreateButton({
    Name = "Refresh Player List",
    Callback = function()
        PlayerDropdown:Refresh(getPlayerNames())
    end,
})

Tab:CreateToggle({
    Name = "Auto Save (1s - Dikey)",
    CurrentValue = false,
    Flag = "TogSave",
    Callback = function(v) config.AutoSave = v end
})

Tab:CreateToggle({
    Name = "Auto Get (> 2s - Alıcı)",
    CurrentValue = false,
    Flag = "TogGet",
    Callback = function(v) config.AutoGet = v end
})

Tab:CreateToggle({
    Name = "Auto Pass (1s - Seçiliye Ver)",
    CurrentValue = false,    Flag = "TogPass",
    Callback = function(v) config.AutoPass = v end
})
